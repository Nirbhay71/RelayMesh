# Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=7100
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/oauth-test-3

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URI=http://localhost:7100/auth/google/callback

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use long random strings)
ACCESS_TOKEN_SECRET=your_very_long_random_access_token_secret_here
REFRESH_TOKEN_SECRET=your_very_long_random_refresh_token_secret_here

ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
